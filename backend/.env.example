# OpenAI API Key (required for story and image generation)
OPENAI_API_KEY=your_openai_api_key_here

# MongoDB Connection URL (MongoDB Atlas recommended)
MONGO_URL=mongodb+srv://username:password@cluster.mongodb.net/anime_generator?retryWrites=true&w=majority

# Replicate API Token (for video generation)
REPLICATE_API_TOKEN=your_replicate_api_token_here

# Pika API Key (alternative video generation)
PIKA_API_KEY=your_pika_api_key_here

# Cloudinary Configuration (for image storage)
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# Environment
ENVIRONMENT=development
